# Chantier migration (Lot 1) — variables de base de données.
# Copier en `.env` (ignoré par git) pour le développement local.
#
# Base LOCALE de dev (SQLite) : suffisante pour prisma validate / migrate / generate.
DATABASE_URL="file:./dev.db"

# Base Turso/libSQL de PRODUCTION (région UE) — À CRÉER PLUS TARD (Lots 4-6).
# Laissées vides ici : tant qu'elles sont absentes, on reste sur le dev.db local.
# TURSO_DATABASE_URL="libsql://<db>-<org>.turso.io"
# TURSO_AUTH_TOKEN="..."
