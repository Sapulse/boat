# Chantier migration (Lot 1) — variables de base de données.
# Copier en `.env` (ignoré par git) pour le développement local.
#
# Base LOCALE de dev (SQLite) : suffisante pour prisma validate / migrate / generate.
DATABASE_URL="file:./dev.db"

# Base Turso/libSQL de PRODUCTION (région UE — Irlande `aws-eu-west-1`, RGPD/SAPulse).
# Créée au Lot 4 (étape web) ; renseignées dans les env vars Vercel (serveur)
# et en local pour le push de schéma. Tant qu'elles sont absentes, on reste sur
# le dev.db local.
# TURSO_DATABASE_URL="libsql://<db>-<org>.turso.io"
# TURSO_AUTH_TOKEN="..."

# Jeton partagé qui protège l'API (Lot 4-6, en attendant l'auth réelle du Lot 7).
# Le client enverra "Authorization: Bearer <valeur>". Sans cette variable côté
# serveur, l'API refuse tout (fail-safe). À définir dans les env vars Vercel.
# API_SHARED_TOKEN="<chaîne-aléatoire-longue>"

# ---------------------------------------------------------------------------
# FEATURE FLAG de bascule client -> API (Lot 5). Vars VITE_* = exposées au
# bundle client. Absent -> mode localStorage (DÉFAUT, flag off) : l'app des
# commerciaux ne change pas. Ne PAS définir ces vars sur la prod GitHub Pages.
# ---------------------------------------------------------------------------
# VITE_USE_API="true"                                  # 'true' -> l'app parle à l'API
# VITE_API_BASE_URL="/api"                             # défaut '/api' (même origine Vercel)
#
# ⚠️⚠️ VITE_API_TOKEN = le jeton d'API DANS LE BUNDLE CLIENT (donc PUBLIC / lisible
# par tous). STAGING/TEST UNIQUEMENT, sous 3 conditions CUMULATIVES obligatoires :
#   (1) base VIERGE / données de test seulement (aucune donnée réelle client) ;
#   (2) Vercel Deployment Protection ACTIVÉE (l'URL de test n'est pas publique) ;
#   (3) usage documenté comme TEMPORAIRE (docs/migration).
# INTERDICTION FORMELLE de partir en prod ainsi. La vraie réponse = auth Lot 7.
# VITE_API_TOKEN="<le-meme-que-API_SHARED_TOKEN>"
